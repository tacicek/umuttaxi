# UmutTaxi Environment Variables Example
# =====================================
# Copy this file to .env.local and fill in your values

# Site Configuration
SITE_URL=http://localhost:4321
SITE_NAME=UmutTaxi
SITE_DESCRIPTION=Premium Taxiservice in Zürich-Schwerzenbach

# Contact Information
CONTACT_PHONE=+41441234567
CONTACT_EMAIL=info@umuttaxi.ch

# Resend Email Configuration
RESEND_API_KEY=your_resend_api_key_here
RESEND_FROM_EMAIL=UmutTaxi <info@taxiumut.ch>
# Where form notifications are delivered (defaults to info@taxiumut.ch).
# MAIL_CC accepts a comma-separated list; leave empty for no CC.
MAIL_TO=info@taxiumut.ch
MAIL_CC=

# Google Maps API (if needed later)
GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# Analytics (if needed later)
GOOGLE_ANALYTICS_ID=your_ga_id_here

# Social Media
FACEBOOK_URL=https://facebook.com/umuttaxi
INSTAGRAM_URL=https://instagram.com/umuttaxi
TWITTER_URL=https://twitter.com/umuttaxi

# Business Information
BUSINESS_ADDRESS=Zürich-Schwerzenbach, Switzerland
BUSINESS_HOURS=24/7

# Development
NODE_ENV=development
